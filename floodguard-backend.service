[Unit]
Description=FloodGuard Python Backend Orchestrator
After=network.target

[Service]
# IMPORTANT: Adjust the 'User' and 'WorkingDirectory' to match your EC2 instance setup
User=admin
WorkingDirectory=/home/admin/e22-co2060-floodguard
Environment="PATH=/home/admin/e22-co2060-floodguard/venv/bin:/usr/bin"
ExecStart=/home/admin/e22-co2060-floodguard/venv/bin/python code/main.py
Restart=always
RestartSec=5
StandardOutput=syslog
StandardError=syslog
SyslogIdentifier=floodguard-backend

[Install]
WantedBy=multi-user.target
